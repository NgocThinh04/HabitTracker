<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9F9"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="100dp"> <!-- Padding đáy để không bị BottomNav che mất -->

        <!-- Tiêu đề trang -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#111111" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Your Improvements"
                android:textColor="#111111"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Thanh cuộn ngang chứa các bộ lọc (Chips) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_round_stats"
                    android:backgroundTint="#111111"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="10dp"
                    android:text="All"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_round_stats"
                    android:backgroundTint="#FFFFFF"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="10dp"
                    android:text="Physical exercise"
                    android:textColor="#555555" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_round_stats"
                    android:backgroundTint="#FFFFFF"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="10dp"
                    android:text="Learning and reflect"
                    android:textColor="#555555" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Khung Header của Thói quen đang chọn -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#222222"
            app:cardCornerRadius="16dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No more than 4 hours..."
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Stop doom scrolling."
                    android:textColor="#AAAAAA"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Khung Thống kê chi tiết (Chart Area) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <!-- Lưới hiển thị các ngày (Vuông bo góc) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <View android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_round_stats" android:backgroundTint="#333333" />
                <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                <View android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_round_stats" android:backgroundTint="#333333" />
                <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                <View android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_round_stats" android:backgroundTint="#333333" />
                <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                <View android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_round_stats" android:backgroundTint="#333333" />
                <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                <View android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_round_stats" android:backgroundTint="#FF4500" />
                <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                <View android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_round_stats" android:backgroundTint="#E0E0E0" />
                <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                <View android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_round_stats" android:backgroundTint="#E0E0E0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="S" android:textAlignment="center" android:textColor="#888" />
                <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="M" android:textAlignment="center" android:textColor="#888" />
                <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="T" android:textAlignment="center" android:textColor="#888" />
                <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="W" android:textAlignment="center" android:textColor="#888" />
                <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="T" android:textAlignment="center" android:textColor="#FF4500" android:textStyle="bold" />
                <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="F" android:textAlignment="center" android:textColor="#888" />
                <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="S" android:textAlignment="center" android:textColor="#888" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>